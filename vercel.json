{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/b/:slug*", "destination": "/brand/dashboard", "permanent": true }
  ],
  "rewrites": [
    { "source": "/r/:slug/admin/:rest*", "destination": "/r/gus/admin/:rest*" },
    { "source": "/r/:slug/admin", "destination": "/r/gus/admin" },
    { "source": "/r/:slug", "destination": "/r/gus" },
    { "source": "/brand/signup", "destination": "/brand/signin" }
  ],
  "crons": [
    { "path": "/api/brand-account?action=cron", "schedule": "0 14 * * *" }
  ]
}
